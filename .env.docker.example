# ─── EvalAI Docker Environment Template ───────────────────────────────────────
# Copy this file to .env.docker and fill in your actual values.
# .env.docker is gitignored. This file IS committed.
# Usage: docker compose --env-file .env.docker up

# ─── PostgreSQL ────────────────────────────────────────────────────────────────
# Password for the PostgreSQL user. Used by the postgres service and api service.
POSTGRES_PASSWORD=change_me_strong_password

# ─── Redis ─────────────────────────────────────────────────────────────────────
# Redis connection URL. Used by FastAPI, Celery worker, and Flower.
REDIS_URL=redis://redis:6379/0

# ─── Supabase ──────────────────────────────────────────────────────────────────
# Your Supabase project URL (e.g. https://xyz.supabase.co)
SUPABASE_URL=https://your-project.supabase.co

# Supabase SERVICE ROLE key (not anon key — this has full DB access).
# Found in: Supabase Dashboard → Project Settings → API → service_role key
# NEVER expose this to the browser or commit to git.
SUPABASE_KEY=your_service_role_key_here

# Supabase storage bucket names (auto-created by the API on startup)
SUPABASE_BUCKET_SHEETS=evalai-sheets
SUPABASE_BUCKET_RUBRICS=evalai-rubrics
SUPABASE_BUCKET_ANNOTATED=evalai-annotated

# ─── Database ──────────────────────────────────────────────────────────────────
# Async PostgreSQL URL for FastAPI (uses asyncpg driver)
DATABASE_URL=postgresql+asyncpg://evalai:${POSTGRES_PASSWORD}@postgres:5432/evalai

# Sync PostgreSQL URL for Celery tasks and Alembic (uses psycopg2)
SYNC_DATABASE_URL=postgresql://evalai:${POSTGRES_PASSWORD}@postgres:5432/evalai

# ─── AI / ML ───────────────────────────────────────────────────────────────────
# Google Gemini API key. Get it at: https://aistudio.google.com
# NEVER commit this value.
GEMINI_API_KEY=your_gemini_api_key_here

# Gemini rate limit (requests per minute). Free tier max = 15. Keep at 12 for safety.
GEMINI_RPM_LIMIT=12

# ─── Authentication ────────────────────────────────────────────────────────────
# JWT signing secret — MINIMUM 32 characters. Generate with: openssl rand -hex 32
# NEVER commit this value.
SECRET_KEY=generate_a_secure_random_key_here

# JWT access token expiry in minutes (10080 = 7 days)
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# ─── Worker Config ─────────────────────────────────────────────────────────────
# Number of concurrent sheet processing workers
MAX_WORKERS=4

# ─── PDF Processing ────────────────────────────────────────────────────────────
# Path to Poppler binary for pdf2image conversion.
# Docker: /usr/bin (installed in Dockerfile)
# macOS: /opt/homebrew/bin  Ubuntu: /usr/bin  Windows: C:\poppler\bin
POPPLER_PATH=/usr/bin

# ─── Application ───────────────────────────────────────────────────────────────
# Environment: development / production
ENVIRONMENT=development

# Comma-separated list of allowed CORS origins
CORS_ORIGINS=http://localhost:3000,http://localhost:8000

# ─── Celery Flower Monitoring ──────────────────────────────────────────────────
# Basic auth credentials for the Flower dashboard at localhost:5555
FLOWER_USER=admin
FLOWER_PASSWORD=change_me_flower_password
